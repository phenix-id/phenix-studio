# -----------------------------------------------------------------------------
# Phenix Studio environment sample
# -----------------------------------------------------------------------------
# Next.js exposes variables prefixed with NEXT_PUBLIC_ to browser bundles.
# Keep secrets unprefixed and use them only from server/runtime code.

# Public browser configuration
NEXT_PUBLIC_MODE=DEV
NEXT_PUBLIC_BASE_URL=http://localhost:5000
NEXT_PUBLIC_ECOSYSTEM_FRONT_END_URL=http://localhost:3001
NEXT_PUBLIC_PLATFORM_NAME=CREDEBL
NEXT_PUBLIC_ACTIVE_THEME=
NEXT_PUBLIC_APP_TITLE=
NEXT_PUBLIC_FOOTER_TEXT=Phenix ID. All rights reserved.
NEXT_PUBLIC_LOGO_BASE_URL=
NEXT_PUBLIC_CURRENT_RELEASE=

# Public feature flags and links
NEXT_PUBLIC_ENABLE_APP_LAUNCHER=false
NEXT_PUBLIC_APP_NAME=Phenix
NEXT_PUBLIC_ENABLE_SOCIAL_LOGIN=false
NEXT_PUBLIC_ENABLE_BILLING_OPTION=true
NEXT_PUBLIC_SOVIO_LANDINGPAGE_URL=

# Public blockchain RPC endpoints
NEXT_PUBLIC_POLYGON_TESTNET_URL=https://rpc-amoy.polygon.technology/
NEXT_PUBLIC_POLYGON_MAINNET_URL=https://polygon-rpc.com/

# Public Marketplace legal/billing labels rendered by Studio
NEXT_PUBLIC_MARKETPLACE_MANAGE_URL=
NEXT_PUBLIC_MARKETPLACE_PRODUCT_NAME=Phenix ID Platform
NEXT_PUBLIC_MARKETPLACE_PUBLISHER_NAME=Phenix
NEXT_PUBLIC_MARKETPLACE_SUPPORT_EMAIL=support@phenix-id.com
NEXT_PUBLIC_MARKETPLACE_PRIVACY_EMAIL=privacy@phenix-id.com

# Server-only NextAuth configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
NEXTAUTH_COOKIE_DOMAIN=localhost
NEXTAUTH_PROTOCOL=http

# Server-side request helper configuration
PUBLIC_ALLOW_DOMAIN="http://localhost:5000 http://localhost:5001 http://localhost:3000 http://localhost:3001 https://cdnjs.cloudflare.com https://tailwindcss.com https://fonts.googleapis.com https://fonts.gstatic.com https://avatars.githubusercontent.com ws://localhost:5000 https://rpc-amoy.polygon.technology/"
PUBLIC_ECOSYSTEM_BASE_URL=
PUBLIC_PLATFORM_DOCS_URL=https://docs.credebl.id/en/intro/what-is-credebl/
